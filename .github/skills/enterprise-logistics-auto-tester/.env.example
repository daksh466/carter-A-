# Environment Configuration Template
# Copy to .env.test and customize for your environment

# Backend API
API_BASE_URL=http://localhost:5000

# Frontend (for Playwright UI testing)
FRONTEND_URL=http://localhost:3000

# Database
DB_CONNECTION_STRING=mongodb://localhost:27017/logistics-test
DB_RESET_ENABLED=true

# Reports
REPORT_DIR=reports/test-results

# Logging & Debugging
VERBOSE=false
HEADLESS=true

# Optional: Custom timeouts (milliseconds)
# TIMEOUT=30000

# Optional: Test-specific flags
# SKIP_DB_RESET=false
# RUN_STRESS_TEST=true
