# Server Configuration
PORT=5000
NODE_ENV=production

# MongoDB
DB_URI=mongodb+srv://username:password@cluster.mongodb.net/carter-prod?retryWrites=true&w=majority
MONGO_URI=

# Web and API
FRONTEND_URL=https://your-frontend-domain.example
SLOW_ENDPOINT_MS=250
METRICS_REQUIRE_AUTH=true
METRICS_AUTH_TOKEN=replace-with-strong-random-token

# Load Test / CI Guard
P95_THRESHOLD_MS=250
AUTH_TOKEN=

# Feature / debug toggles
SPAREPART_BATCH_DEBUG=false
TRANSFER_DEBUG=false

# JWT Authentication
JWT_SECRET=your-super-secret-jwt-key-change-in-production

# PDF Storage
PDF_STORAGE_PATH=./pdfs

# Logging
LOG_LEVEL=info

# Bcrypt
BCRYPT_SALT_ROUNDS=10
